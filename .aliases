# cheatsheet
alias cheat="bat --style=plain --language=md ~/.cheatsheet.md 2>/dev/null || cat ~/.cheatsheet.md"

# work-specific
alias pp="just pp"
alias dev="just dev-start-web"
alias init="git pull && pp && dev"
alias integration="just dev-start-integration"
alias types="turbo generate-types"
alias typecheck="turbo typecheck"
alias typecheck-web="turbo typecheck -F web-client"
alias typecheck-access="turbo typecheck -F @vanta/access-management"
alias make-types="just generate-types"
alias story="just dev-storybook"
alias test="just unit-test"
alias test-am-ws="turbo unit-test -F @vanta/access-management"

# claude with access-mgmt knowledge base
claude-apps() {
  local kb="$HOME/access-mgmt-knowledge-base"
  if ! command -v claude >/dev/null 2>&1; then
    echo "claude not found — is Claude Code installed?"
    return 1
  fi
  if [ -d "$kb/.git" ]; then
    git -C "$kb" pull --ff-only --quiet 2>/dev/null || echo "KB: pull failed, using cached version"
  else
    echo "KB not found at $kb — run install.sh first"
    return 1
  fi
  claude --add-dir "$kb" "$@"
}